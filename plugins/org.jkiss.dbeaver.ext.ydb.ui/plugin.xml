    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.dbeaver.ext.ydb.table.row.create"
               icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/table_row.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.table.column.create"
               icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/table_column.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.topic.create"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.view.create"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.external.datasource.create.object_storage"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.external.datasource.create.ydb"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.csv"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.json"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.parquet"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.transfer.create"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
        <image commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.create"
               icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg"/>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <!-- External Data Sources: sub-menu "Create new" with ObjectStorage and YDB -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <menu id="org.jkiss.dbeaver.ext.ydb.external.datasource.create.menu" label="%command.external_datasource.create.menu.label" icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg">
                <command commandId="org.jkiss.dbeaver.ext.ydb.external.datasource.create.object_storage">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <command commandId="org.jkiss.dbeaver.ext.ydb.external.datasource.create.ydb">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <visibleWhen>
                    <with variable="selection">
                        <count value="1"/>
                        <iterate operator="and">
                            <or>
                                <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalDataSources" forcePluginActivation="true"/>
                                <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                    <or>
                                        <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalDataSourceFolder"/>
                                        <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalDataSource"/>
                                    </or>
                                </adapt>
                            </or>
                        </iterate>
                    </with>
                </visibleWhen>
            </menu>
        </menuContribution>
        <!-- Tables: sub-menu "Create new" with Row-based and Column-based -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <menu id="org.jkiss.dbeaver.ext.ydb.table.create.menu" label="%command.table.create.menu.label" icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg">
                <command commandId="org.jkiss.dbeaver.ext.ydb.table.row.create">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <command commandId="org.jkiss.dbeaver.ext.ydb.table.column.create">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <visibleWhen>
                    <with variable="selection">
                        <count value="1"/>
                        <iterate operator="and">
                            <or>
                                <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbTables" forcePluginActivation="true"/>
                                <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                    <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBTableFolder"/>
                                </adapt>
                            </or>
                        </iterate>
                    </with>
                </visibleWhen>
            </menu>
        </menuContribution>
        <!-- Topics -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <command commandId="org.jkiss.dbeaver.ext.ydb.topic.create">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <!-- Views -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <command commandId="org.jkiss.dbeaver.ext.ydb.view.create">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <!-- External Tables: sub-menu "Create new" with CSV, JSON, Parquet -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <menu id="org.jkiss.dbeaver.ext.ydb.external.table.create.menu" label="%command.external_table.create.menu.label" icon="platform:/plugin/org.jkiss.dbeaver.ui/icons/create.svg">
                <command commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.csv">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <command commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.json">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <command commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.parquet">
                    <visibleWhen checkEnabled="true"/>
                </command>
                <visibleWhen>
                    <with variable="selection">
                        <count value="1"/>
                        <iterate operator="and">
                            <or>
                                <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalTables" forcePluginActivation="true"/>
                                <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                    <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalTableFolder"/>
                                </adapt>
                            </or>
                        </iterate>
                    </with>
                </visibleWhen>
            </menu>
        </menuContribution>
        <!-- Transfers -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <command commandId="org.jkiss.dbeaver.ext.ydb.transfer.create">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <!-- Streaming Queries -->
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <command commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.create">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=navigator_additions_end">
            <command commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.alter">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=navigator_additions_end">
            <command commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.stop">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=navigator_additions_end">
            <command commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.start">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <!-- Statistics button in SQL editor toolbar (YDB only) -->
        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.dbeaver.ui.editors.sql.toolbar.side.top">
            <command commandId="org.jkiss.dbeaver.ext.ydb.run.statistics"
                     label="%command.statistics.name"
                     icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/statistics.svg"
                     tooltip="%command.statistics.description"
                     style="push">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <!-- Chart button in SQL editor toolbar (YDB only) -->
        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.dbeaver.ui.editors.sql.toolbar.side.top">
            <command commandId="org.jkiss.dbeaver.ext.ydb.run.chart"
                     label="%command.chart.name"
                     icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/chart.svg"
                     tooltip="%command.chart.description"
                     style="push">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
    </extension>

    <!-- YDB Graphical Plan Viewer for EXPLAIN -->
    <extension point="org.jkiss.dbeaver.sql.plan.view">
        <view id="ydb-diagram"
              priority="50"
              label="%sql.plan.view.diagram.name"
              icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/ydb_icon.png"
              description="%sql.plan.view.diagram.tip"
              class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBSQLPlanViewProvider">
            <datasource id="ydb"/>
        </view>
        <view id="ydb-statistics-svg"
              priority="40"
              label="%sql.plan.view.statistics.name"
              icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/ydb_icon.png"
              description="%sql.plan.view.statistics.tip"
              class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStatisticsSvgViewProvider">
            <datasource id="ydb"/>
        </view>
    </extension>

    <!-- YDB Dashboard Charts -->
    <extension point="org.jkiss.dbeaver.dashboard.ui">
        <dashboardView id="ydb-viewer" label="YDB Viewer"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/ydb_icon.png"
            dataTypes="provided"
            renderer="org.jkiss.dbeaver.ext.ydb.ui.dashboard.YDBDashboardRenderer"
            configurationEditor="org.jkiss.dbeaver.ext.ydb.ui.dashboard.YDBDashboardConfigEditor"
            viewSettingsEditor="org.jkiss.dbeaver.ext.ydb.ui.dashboard.YDBDashboardViewSettingsEditor"/>
    </extension>

    <extension point="org.jkiss.dbeaver.dashboard">
        <dashboard id="ydb.cpu" label="CPU Load" defaultView="ydb-viewer"
            group="Database Load" showByDefault="true" value="percent" measure="%"
            updatePeriod="5000" description="YDB cluster CPU usage">
            <datasource id="ydb"/>
        </dashboard>
        <dashboard id="ydb.storage" label="Storage" defaultView="ydb-viewer"
            group="Database Load" showByDefault="true" value="bytes"
            updatePeriod="5000" description="YDB cluster storage usage">
            <datasource id="ydb"/>
        </dashboard>
        <dashboard id="ydb.memory" label="Memory" defaultView="ydb-viewer"
            group="Database Load" showByDefault="true" value="bytes"
            updatePeriod="5000" description="YDB cluster memory usage">
            <datasource id="ydb"/>
        </dashboard>
        <dashboard id="ydb.network" label="Network" defaultView="ydb-viewer"
            group="Database Load" showByDefault="true" value="bytes" measure="KB/s"
            updatePeriod="5000" description="YDB network write throughput">
            <datasource id="ydb"/>
        </dashboard>
        <dashboard id="ydb.queries" label="Running Queries" defaultView="ydb-viewer"
            group="Database Load" showByDefault="true" value="integer"
            updatePeriod="5000" description="Number of concurrently running queries">
            <datasource id="ydb"/>
        </dashboard>
    </extension>

