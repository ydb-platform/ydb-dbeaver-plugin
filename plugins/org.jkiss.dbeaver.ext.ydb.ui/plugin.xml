<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.dbeaver.dataSourceView">
        <view
            id="org.jkiss.dbeaver.ext.ydb.dataSourceWizardView"
            dataSource="ydb"
            targetID="org.jkiss.dbeaver.ext.ui.newConnectionWizard"
            label="%dialog.connection.header"
            class="org.jkiss.dbeaver.ext.ydb.ui.YDBConnectionPage"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/ydb_icon.png">
        </view>
        <view
            id="org.jkiss.dbeaver.ext.ydb.dataSourceEditorView"
            dataSource="ydb"
            targetID="org.jkiss.dbeaver.ext.ui.editConnectionDialog"
            label="%dialog.connection.header"
            class="org.jkiss.dbeaver.ext.ydb.ui.YDBConnectionPage"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/ydb_icon.png">
        </view>
    </extension>

    <!-- Session Manager Editor -->
    <extension point="org.jkiss.dbeaver.dataSourceProvider">
        <editorContribution
            editorId="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBSessionEditor"
            category="connectionEditor"
            label="%editor.session_manager.name"
            icon="platform:/plugin/org.jkiss.dbeaver.model/icons/tree/sessions.svg">
            <supports dataSource="ydb"/>
        </editorContribution>
    </extension>

    <!-- Database Load Dashboard Editor -->
    <extension point="org.jkiss.dbeaver.dataSourceProvider">
        <editorContribution
            editorId="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBDatabaseLoadEditor"
            category="connectionEditor"
            label="%editor.database_load.name"
            icon="platform:/plugin/org.jkiss.dbeaver.model/icons/tree/info.svg">
            <supports dataSource="ydb"/>
        </editorContribution>
    </extension>

    <!-- Convert Dialect Editor -->
    <extension point="org.jkiss.dbeaver.dataSourceProvider">
        <editorContribution
            editorId="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBConvertDialectEditor"
            category="connectionEditor"
            label="%editor.convert.dialect.name"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/convert.svg">
            <supports dataSource="ydb"/>
        </editorContribution>
    </extension>

    <extension point="org.eclipse.ui.editors">
        <editor
            name="%editor.session_manager.name"
            icon="platform:/plugin/org.jkiss.dbeaver.model/icons/tree/sessions.svg"
            class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBSessionEditor"
            id="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBSessionEditor"
            contributorClass="org.jkiss.dbeaver.ui.editors.EditorSearchActionsContributor">
        </editor>
        <editor
            name="%editor.database_load.name"
            icon="platform:/plugin/org.jkiss.dbeaver.model/icons/tree/info.svg"
            class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBDatabaseLoadEditor"
            id="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBDatabaseLoadEditor"
            contributorClass="org.jkiss.dbeaver.ui.editors.EditorSearchActionsContributor">
        </editor>
        <editor
            name="%editor.convert.dialect.name"
            icon="platform:/plugin/org.jkiss.dbeaver.ext.ydb/icons/convert.svg"
            class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBConvertDialectEditor"
            id="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBConvertDialectEditor"
            contributorClass="org.jkiss.dbeaver.ui.editors.EditorSearchActionsContributor">
        </editor>
    </extension>

    <!-- Alter Streaming Query command -->
    <extension point="org.eclipse.ui.commands">
        <category id="org.jkiss.dbeaver.ext.ydb" name="YDB" description="YDB Commands"/>
        <command id="org.jkiss.dbeaver.ext.ydb.external.datasource.create.object_storage"
                 name="%command.external_datasource.create.object_storage.name"
                 description="%command.external_datasource.create.object_storage.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.external.datasource.create.ydb"
                 name="%command.external_datasource.create.ydb.name"
                 description="%command.external_datasource.create.ydb.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.table.row.create"
                 name="%command.table.row.create.name"
                 description="%command.table.row.create.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.table.column.create"
                 name="%command.table.column.create.name"
                 description="%command.table.column.create.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.topic.create"
                 name="%command.topic.create.name"
                 description="%command.topic.create.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.view.create"
                 name="%command.view.create.name"
                 description="%command.view.create.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.external.table.create.csv"
                 name="%command.external_table.create.csv.name"
                 description="%command.external_table.create.csv.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.external.table.create.json"
                 name="%command.external_table.create.json.name"
                 description="%command.external_table.create.json.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.external.table.create.parquet"
                 name="%command.external_table.create.parquet.name"
                 description="%command.external_table.create.parquet.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.transfer.create"
                 name="%command.transfer.create.name"
                 description="%command.transfer.create.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.streaming.query.create"
                 name="%command.streaming_query.create.name"
                 description="%command.streaming_query.create.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.streaming.query.alter"
                 name="%command.streaming_query.alter.name"
                 description="%command.streaming_query.alter.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.streaming.query.stop"
                 name="%command.streaming_query.stop.name"
                 description="%command.streaming_query.stop.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.streaming.query.start"
                 name="%command.streaming_query.start.name"
                 description="%command.streaming_query.start.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.run.statistics"
                 name="%command.statistics.name"
                 description="%command.statistics.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
        <command id="org.jkiss.dbeaver.ext.ydb.run.chart"
                 name="%command.chart.name"
                 description="%command.chart.description"
                 categoryId="org.jkiss.dbeaver.ext.ydb"/>
    </extension>

    <extension point="org.eclipse.core.expressions.propertyTesters">
        <propertyTester
            id="org.jkiss.dbeaver.ext.ydb.streaming.query.propertyTester"
            class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStreamingQueryPropertyTester"
            namespace="org.jkiss.dbeaver.ext.ydb.streaming.query"
            properties="isRunning"
            type="org.jkiss.dbeaver.ext.ydb.model.YDBStreamingQuery"/>
        <propertyTester
            id="org.jkiss.dbeaver.ext.ydb.folder.propertyTester"
            class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBFolderPropertyTester"
            namespace="org.jkiss.dbeaver.ext.ydb.folder"
            properties="folderId"
            type="java.lang.Object"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.dbeaver.ext.ydb.external.datasource.create.object_storage"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBExtDsObjectStorageCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalDataSources" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <or>
                                    <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalDataSourceFolder"/>
                                    <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalDataSource"/>
                                </or>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.external.datasource.create.ydb"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBExtDsYdbCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalDataSources" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <or>
                                    <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalDataSourceFolder"/>
                                    <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalDataSource"/>
                                </or>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.table.row.create"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBRowTableCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbTables" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBTableFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.table.column.create"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBColumnTableCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbTables" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBTableFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.topic.create"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBTopicCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbTopics" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBTopicFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.view.create"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBViewCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbViews" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBViewFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.csv"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBExtTableCsvCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalTables" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalTableFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.json"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBExtTableJsonCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalTables" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalTableFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.external.table.create.parquet"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBExtTableParquetCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbExternalTables" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBExternalTableFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.transfer.create"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBTransferCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbTransfers" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBTransferFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.create"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStreamingQueryCreateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <or>
                            <test property="org.jkiss.dbeaver.ext.ydb.folder.folderId" value="ydbStreamingQueries" forcePluginActivation="true"/>
                            <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBStreamingQueryFolder"/>
                            </adapt>
                        </or>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.alter"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStreamingQueryAlterHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                            <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBStreamingQuery"/>
                        </adapt>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.stop"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStreamingQueryStopHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                            <and>
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBStreamingQuery"/>
                                <test property="org.jkiss.dbeaver.ext.ydb.streaming.query.isRunning" value="true" forcePluginActivation="true"/>
                            </and>
                        </adapt>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.streaming.query.start"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStreamingQueryStartHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="1"/>
                    <iterate operator="and">
                        <adapt type="org.jkiss.dbeaver.model.struct.DBSObject">
                            <and>
                                <instanceof value="org.jkiss.dbeaver.ext.ydb.model.YDBStreamingQuery"/>
                                <test property="org.jkiss.dbeaver.ext.ydb.streaming.query.isRunning" value="false" forcePluginActivation="true"/>
                            </and>
                        </adapt>
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.run.statistics"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBStatisticsHandler">
        </handler>
        <handler commandId="org.jkiss.dbeaver.ext.ydb.run.chart"
                 class="org.jkiss.dbeaver.ext.ydb.ui.editors.YDBChartHandler">
